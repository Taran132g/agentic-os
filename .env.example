# Copy to .env and fill in your values

ANTHROPIC_API_KEY=sk-ant-...
TELEGRAM_BOT_TOKEN=...         # From @BotFather on Telegram
TELEGRAM_CHAT_ID=...           # Your personal chat ID (send /start to your bot, then check)
GITHUB_TOKEN=...               # GitHub personal access token (repo + PR read scope)

# Vault path (default is correct for macOS iCloud)
VAULT_PATH=/Users/taranveersingh/Library/Mobile Documents/iCloud~md~obsidian/Documents/Digital Brain

# ── Dr. Profit signal monitor (Telegram user account, Pyrogram) ──
TELEGRAM_API_ID=...            # from https://my.telegram.org/apps
TELEGRAM_API_HASH=...
DR_PROFIT_CHANNEL=...          # @channel (public) or -100123... (private id)
DR_PROFIT_MONITOR_DISABLED=1   # 1 on the Mac (monitor runs on Oracle); 0 where it should listen

# ── Live execution: Dr. Profit auto-executor → Yubit USDT-M perps ──
# Safe by default. A real order fires ONLY when EXECUTION_MODE=testnet|live AND
# DR_PROFIT_AUTO_EXECUTE=1 AND EXEC_KILL_SWITCH=0 AND the matching keys are set.
EXECUTION_MODE=dry_run         # dry_run | testnet | live
DR_PROFIT_AUTO_EXECUTE=0       # 1 to arm auto-execution
EXEC_KILL_SWITCH=0             # 1 = block all execution instantly (panic switch)
EXEC_MAX_NOTIONAL_USD=100      # per-trade position value cap (clamps down)
EXEC_MAX_LEVERAGE=10           # leverage clamp regardless of signal
EXEC_MAX_CONCURRENT=3          # max simultaneous auto positions
EXEC_MAX_TRADES_PER_DAY=10
EXEC_DAILY_LOSS_STOP_USD=200   # halt auto-exec once today's realized loss exceeds this
EXEC_MIN_CONFIDENCE=55         # min agent confidence (0-100) to act
EXEC_RISK_GATE_BLOCKS=1        # 1 = a risk-gate REJECT blocks the trade
EXEC_ALLOWED_ASSETS=           # optional CSV allowlist, e.g. BTC,ETH,SOL (blank = all)

# Yubit API keys — trade permission, IP-restrict to Oracle, DISABLE withdrawals.
YUBIT_API_KEY=                 # live
YUBIT_API_SECRET=
YUBIT_TESTNET_API_KEY=         # testnet (validate here first)
YUBIT_TESTNET_API_SECRET=
# Optional overrides if the live docs differ from the built-in defaults:
# YUBIT_BASE_URL=https://openapi.yubit.com
# YUBIT_TESTNET_BASE_URL=https://testnet-openapi.yubit.com
# YUBIT_API_KEY_HEADER=X-MBX-APIKEY
# YUBIT_QTY_DECIMALS=6
